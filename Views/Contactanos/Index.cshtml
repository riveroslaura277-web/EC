@{
    ViewData["Title"] = "Contacto";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/Contactanos.css" asp-append-version="true" />

<!--=========================================
                NAVBAR
==========================================-->

<header class="navbar">

    <div class="logo">

        <img src="~/EVIDENCIAS/Logo.png"
             asp-append-version="true"
             alt="EduClick" />

        <div class="logo-text">

            <h2>Edu<span>Click</span></h2>

            <p>Aprender es una aventura</p>

        </div>

    </div>

    <nav class="menu">

        <a asp-controller="Home" asp-action="Index">
            <i class="fa-solid fa-house"></i>
            Inicio
        </a>

        <a asp-controller="Beneficios" asp-action="Index">
            <i class="fa-solid fa-star"></i>
            Beneficios
        </a>

        <a asp-controller="Nosotros" asp-action="Index">
            <i class="fa-solid fa-book-open"></i>
            Nosotros
        </a>

        <a asp-controller="Contactanos"
           asp-action="Index"
           class="active">

            <i class="fa-solid fa-phone"></i>
            Contacto

        </a>

    </nav>

</header>


<!--=========================================
                CONTACTO
==========================================-->

<section class="contacto">

    <!-- izquierda -->

    <div class="contacto-info">

        <span class="etiqueta">

            ⭐ CONTACTO

        </span>

        <h1>

            ¡Contáctanos!

            <span>Estamos aquí para ayudarte</span>

        </h1>

        <p>

            ¿Tienes dudas, sugerencias o necesitas ayuda?

            Nuestro equipo está listo para acompañarte.

            <strong>¡Escríbenos!</strong>

        </p>

        <div class="hero-right">

            <img src="~/CONTACTOS/tigre.png"
                 asp-append-version="true"
                 alt="EduClick" />

        </div>

    </div>


    <!-- tarjetas -->

    <div class="contacto-grid">

        <!-- tarjeta 1 -->

        <div class="card-contacto">

            <div class="icono">

                <img src="~/CONTACTOS/correo.png"
                     asp-append-version="true" />

            </div>

            <h3 class="morado">

                Correo Electrónico

            </h3>

            <p>

                Escríbenos y te responderemos
                lo antes posible.

            </p>

            <div class="dato morado-box">

                hola@eduClick.com

            </div>

        </div>


        <!-- tarjeta 2 -->

        <div class="card-contacto">

            <div class="icono">

                <img src="~/CONTACTOS/contacto .png"
                     asp-append-version="true" />

            </div>

            <h3 class="verde">

                WhatsApp

            </h3>

            <p>

                Chatea con nosotros
                para atención más rápida.

            </p>

            <div class="dato verde-box">

                +57 300 123 4567

            </div>

        </div>


        <!-- tarjeta 3 -->

        <div class="card-contacto">

            <div class="icono">

                <img src="~/CONTACTOS/llamanos.png"
                     asp-append-version="true" />

            </div>

            <h3 class="naranja">

                Llámanos

            </h3>

            <p>

                Estamos disponibles
                de lunes a viernes.

            </p>

            <div class="dato naranja-box">

                +57 601 123 4567

            </div>

        </div>


        <!-- tarjeta 4 -->

        <div class="card-contacto">

            <div class="icono">

                <img src="~/CONTACTOS/ubicacion.png"
                     asp-append-version="true" />

            </div>

            <h3 class="azul">

                Nuestra Ubicación

            </h3>

            <p>

                Visítanos en nuestras oficinas
                y conócenos en persona.

            </p>

            <div class="dato azul-box">

                Bogotá, Colombia

            </div>

        </div>


        <!-- tarjeta 5 -->

        <div class="card-contacto">

            <div class="icono">

                <img src="~/CONTACTOS/contacto .png"
                     asp-append-version="true" />

            </div>

            <h3 class="rosado">

                Formulario

            </h3>

            <p>

                Completa nuestro formulario
                y te contactaremos.

            </p>

            <div class="dato rosado-box">

                Ir al formulario

            </div>

        </div>


        <!-- tarjeta 6 -->

        <div class="card-contacto">

            <div class="icono">

                <img src="~/CONTACTOS/horarios.png"
                     asp-append-version="true" />

            </div>

            <h3 class="violeta">

                Horarios

            </h3>

            <p>

                Estamos para ayudarte
                en el horario que necesites.

            </p>

            <div class="dato violeta-box">

                Lun - Vie 8am - 6pm

            </div>

        </div>

    </div>

</section>


<!--=========================================
                BANNER
==========================================-->

<section class="banner-contacto">

    <div class="banner-contenido">

        <div class="banner-texto">

            <div class="banner-icono">

                🧪

            </div>

            <div>

                <h2>

                    ¡Tu aprendizaje es nuestra misión!

                </h2>

                <p>

                    En EduClick cada mensaje cuenta.

                    Estamos aquí para ayudarte

                    <span>a crecer.</span>

                </p>

            </div>

        </div>       

    </div>

</section>