@{
    ViewData["Title"] = "Dashboard Estudiante";
    Layout = null;
}

<link rel="stylesheet" href="~/css/estudiante-dashboard.css" />

<div class="dashboard-container">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <!-- LOGO -->
        <div class="logo-box">

            <img src="~/ImageNinos/Logo.png" alt="Logo">

            <div>
                <h2>EduClick</h2>
                <p>Aprender es la aventura más emocionante</p>
            </div>

        </div>


        <!-- MENU -->
        <nav class="menu">

            <a href="#" class="active">
                <span>🏠 Inicio</span>
            </a>

            <a href="#">
                <span>📋 Mis Materias</span>
            </a>

            <a href="#">
                <span>📑 Actividades</span>
            </a>

            <a href="#">
                <span>🎮 Juegos</span>
            </a>

            <a href="#">
                <span>▶️ Videos</span>
            </a>

            <a href="#">
                <span>🤖 Chat IA</span>
            </a>

            <a href="#">
                <span>🏆 Retos</span>
            </a>

            <a href="#">
                <span>🏅 Logros</span>
            </a>

            <a href="#">
                <span>👤 Mi Perfil</span>
            </a>

        </nav>

        <!-- TIGRE -->
        <div class="tigre-box">
            <img src="~/ImageNinos/tigre_leyendo.png" class="tigre" />
        </div>

    </aside>

    <!-- MAIN -->
    <main class="main-content">

        <!-- TOPBAR -->
        <header class="topbar">

            <div class="welcome">

                <h1>¡Hola, Sofía! 👋</h1>

                <p>
                    Qué bueno verte de nuevo.
                    ¡Sigue aprendiendo y alcanzando tus metas!
                </p>

            </div>

            <div class="top-actions">

                <!-- PUNTOS -->
                <div class="points">

                    <img src="~/ImageNinos/puntos.png" alt="">
                    <span>1200</span>

                </div>

                <!-- NOTIFICACION -->
                <div class="notification">

                    🔔
                    <span>3</span>

                </div>

                <!-- PERFIL -->
                <div class="profile">

                    <img src="~/ImageNinos/iconoavatar.png" alt="">

                    <div>

                        <h4>Sofía</h4>
                        <p>Estudiante</p>

                    </div>

                </div>

            </div>

        </header>

        <!-- HERO -->
        <section class="hero-section">

            <!-- BANNER -->
            <div class="hero-left">

                <div class="hero-text">

                    <h2>
                        Cada día es una nueva oportunidad para
                        <span>aprender</span>
                    </h2>

                    <p>
                        Explora, juega, descubre y aprende
                        cosas increíbles.
                    </p>

                    <button>
                        ¡Explorar ahora! →
                    </button>

                </div>

            </div>

            <!-- PROGRESO -->
            <div class="progress-card">

                <h3>Mi progreso</h3>

                <div class="circle">
                    <span>65%</span>
                </div>

                <p>¡Vas por buen camino!</p>

                <div class="stats">

                    <div>
                        ⭐
                        <span>1200</span>
                        <small>Puntos</small>
                    </div>

                    <div>
                        🔥
                        <span>15</span>
                        <small>Días</small>
                    </div>

                    <div>
                        🏅
                        <span>7</span>
                        <small>Nivel</small>
                    </div>

                </div>

            </div>

        </section>

        <!-- MATERIAS -->
        <section class="subjects-section">

            <div class="section-header">

                <h2>🍃 Mis materias</h2>

                <a href="#">Ver todas →</a>

            </div>

            <div class="subjects-grid">

                <!-- MATEMATICAS -->
                <div class="subject-card math">

                    <img src="~/ImageNinos/icono matematicas.png" alt="">

                    <h3>Matemáticas</h3>

                    <p>
                        Números y operaciones.
                    </p>

                    <div class="bar">
                        <div style="width:75%"></div>
                    </div>

                    <span>75%</span>

                </div>

                <!-- LECTURA -->
                <div class="subject-card reading">

                    <img src="~/ImageNinos/icono lectura.png" alt="">

                    <h3>Lectura</h3>

                    <p>
                        Mejora tu comprensión.
                    </p>

                    <div class="bar">
                        <div style="width:60%"></div>
                    </div>

                    <span>60%</span>

                </div>

                <!-- CIENCIAS -->
                <div class="subject-card science">

                    <img src="~/ImageNinos/icono ciencias.png" alt="">

                    <h3>Ciencias</h3>

                    <p>
                        Descubre el mundo.
                    </p>

                    <div class="bar">
                        <div style="width:80%"></div>
                    </div>

                    <span>80%</span>

                </div>

                <!-- SOCIALES -->
                <div class="subject-card social">

                    <img src="~/ImageNinos/icono sociales.png" alt="">

                    <h3>Sociales</h3>

                    <p>
                        Aprende historia.
                    </p>

                    <div class="bar">
                        <div style="width:70%"></div>
                    </div>

                    <span>70%</span>

                </div>

                <!-- INGLES -->
                <div class="subject-card english">

                    <img src="~/ImageNinos/icono ingles.png" alt="">

                    <h3>Inglés</h3>

                    <p>
                        Aprende jugando.
                    </p>

                    <div class="bar">
                        <div style="width:65%"></div>
                    </div>

                    <span>65%</span>

                </div>

                <!-- TECNOLOGIA -->
                <div class="subject-card tech">

                    <img src="~/ImageNinos/icono tecnologia.png" alt="">

                    <h3>Tecnología</h3>

                    <p>
                        Explora creatividad.
                    </p>

                    <div class="bar">
                        <div style="width:85%"></div>
                    </div>

                    <span>85%</span>

                </div>

            </div>

        </section>

    </main>

</div>