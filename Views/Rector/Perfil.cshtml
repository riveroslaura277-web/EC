@model EC.Models.PerfilViewModel
@{
    Layout = null;
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" />
<link rel="stylesheet" href="~/css/RolRector.css" />

<div style="padding:24px;max-width:700px">

    @if (TempData["Mensaje"] != null)
    {
    <div style="background:#E1F5EE;border:1px solid #1D9E75;border-radius:8px;padding:10px 16px;margin-bottom:16px;font-size:.85rem;color:#085041;font-weight:600">
        ✓ @TempData["Mensaje"]
    </div>
    }



    <!-- ENCABEZADO -->
    <div style="display:flex;align-items:center;gap:20px;margin-bottom:28px">
        <div style="width:72px;height:72px;border-radius:50%;background:#1D9E75;display:grid;place-items:center;font-size:28px;font-weight:700;color:#fff;flex-shrink:0">
            @Model.Nombre.Substring(0, 1).ToUpper()
        </div>
        <a href="@Url.Action("RolRector","Rector")"
           style="display:inline-flex;align-items:center;gap:6px;color:#718096;font-size:.8rem;font-weight:600;text-decoration:none;margin-bottom:8px">
            <i class="ti ti-arrow-left"></i> Volver al Dashboard
        </a>
        <div>
            <div style="font-size:1.3rem;font-weight:700;color:#1a202c">@Model.Nombre</div>
            <div style="font-size:.85rem;color:#718096">@Model.Cargo — @Model.Institucion</div>
            <div style="font-size:.8rem;color:#a0aec0">@Model.Correo</div>
        </div>
    </div>

    <!-- FORMULARIO -->
    <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:24px">
        <h3 style="font-size:.95rem;font-weight:700;color:#1a202c;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #e2e8f0">
            <i class="ti ti-user-edit"></i> Editar información
        </h3>

        <form method="post" action="@Url.Action("Perfil","Rector")">
            @Html.AntiForgeryToken()

            <div style="display:flex;flex-direction:column;gap:16px">

                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#4a5568;display:block;margin-bottom:4px">Nombre completo</label>
                    <input asp-for="Nombre" style="width:100%;padding:9px 12px;border:1px solid #e2e8f0;border-radius:7px;font-family:inherit;font-size:.88rem;outline:none" />
                </div>

                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#4a5568;display:block;margin-bottom:4px">Correo electrónico</label>
                    <input asp-for="Correo" type="email" disabled
                           style="width:100%;padding:9px 12px;border:1px solid #e2e8f0;border-radius:7px;font-family:inherit;font-size:.88rem;background:#f7fafc;color:#a0aec0;outline:none" />
                    <p style="font-size:.7rem;color:#a0aec0;margin-top:3px">El correo no se puede cambiar porque viene de Google.</p>
                </div>

                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#4a5568;display:block;margin-bottom:4px">Teléfono</label>
                    <input asp-for="Telefono" placeholder="Ej: 3101234567"
                           style="width:100%;padding:9px 12px;border:1px solid #e2e8f0;border-radius:7px;font-family:inherit;font-size:.88rem;outline:none" />
                </div>

                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#4a5568;display:block;margin-bottom:4px">Cargo</label>
                    <input asp-for="Cargo" disabled
                           style="width:100%;padding:9px 12px;border:1px solid #e2e8f0;border-radius:7px;font-family:inherit;font-size:.88rem;background:#f7fafc;color:#a0aec0;outline:none" />
                    <p style="font-size:.7rem;color:#a0aec0;margin-top:3px">El cargo es asignado por el sistema.</p>
                </div>

                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#4a5568;display:block;margin-bottom:4px">Institución</label>
                    <input asp-for="Institucion"
                           style="width:100%;padding:9px 12px;border:1px solid #e2e8f0;border-radius:7px;font-family:inherit;font-size:.88rem;outline:none" />
                </div>

                <div style="display:flex;gap:10px;margin-top:8px">
                    <a href="@Url.Action("RolRector","Rector")"
                       style="flex:1;padding:10px;background:#f7fafc;border:1px solid #e2e8f0;border-radius:7px;text-align:center;text-decoration:none;color:#4a5568;font-size:.85rem;font-weight:600">
                        Cancelar
                    </a>
                    <button type="submit"
                            style="flex:1;padding:10px;background:#1D9E75;color:#fff;border:none;border-radius:7px;cursor:pointer;font-family:inherit;font-size:.85rem;font-weight:700">
                        <i class="ti ti-device-floppy"></i> Guardar cambios
                    </button>
                </div>

            </div>
        </form>
    </div>
</div>