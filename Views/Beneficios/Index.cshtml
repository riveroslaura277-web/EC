@{
    ViewData["Title"] = "Beneficios";
    Layout = "_Layout";
}
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Beneficios.css" asp-append-version="true" />


<!--=========================================
                NAVBAR
==========================================-->

<header class="navbar">

    <!--=========================
            LOGO
    =========================-->

    <div class="logo">

        <img src="~/EVIDENCIAS/Logo.png"
             asp-append-version="true"
             alt="EduClick" />

        <div class="logo-text">

            <h2>
                Edu<span>Click</span>
            </h2>

        </div>

    </div>

    <!--=========================
            MENÚ
    =========================-->

    <nav class="menu">

        <a asp-controller="Home"
           asp-action="Index">

            <i class="fa-solid fa-house"></i>

            <span>Inicio</span>

        </a>

        <a asp-controller="Beneficios"
           asp-action="Index"
           class="active">

            <i class="fa-solid fa-star"></i>

            <span>Beneficios</span>

        </a>

        <a asp-controller="Nosotros"
           asp-action="Index">

            <i class="fa-solid fa-users"></i>

            <span>Nosotros</span>

        </a>

        <a asp-controller="Contactanos"
           asp-action="Index">

            <i class="fa-solid fa-phone"></i>

            <span>Contacto</span>

        </a>

    </nav>

</header>

<!--=========================================
            BENEFICIOS
==========================================-->

<section class="beneficios">

    <!--=========================
        INFORMACIÓN
    =========================-->

    <div class="beneficios-info">

        <span class="etiqueta">

            BENEFICIOS ⭐

        </span>

        <h1>

            Beneficios de

            <span>EduClick</span>

        </h1>

        <p>

            Diseñada especialmente para acompañar a los niños
            de primaria en su aventura de aprender mediante
            juegos, actividades y contenido interactivo.

        </p>

        <div class="hero-right">

            <img src="~/BENEFICIOS/tigre.png"
                 alt="tigre">

        </div>

    </div>

    <!--=========================
            TARJETAS
    =========================-->

    <div class="beneficios-grid">

        <!-- Tarjeta 1 -->

        <div class="card-beneficio">

            

            <div class="icono">
                <img src="~/BENEFICIOS/consola.png"
                     asp-append-version="true"
                     alt="">
            </div>

            <h3 class="morado-text">
                Aprendizaje divertido
            </h3>

            <p>
                Juegos, retos y actividades interactivas que convierten
                el estudio en una experiencia emocionante para los niños.
            </p>

        </div>

        <!-- Tarjeta 2 -->

        <div class="card-beneficio">

            

            <div class="icono">
                <img src="~/BENEFICIOS/desarrollo.png"
                     asp-append-version="true"
                     alt="">
            </div>

            <h3 class="verde-text">
                Desarrollo integral
            </h3>

            <p>
                Fortalece habilidades cognitivas,
                emocionales, creativas y sociales
                mediante actividades dinámicas.
            </p>

        </div>

        <!-- Tarjeta 3 -->

        <div class="card-beneficio">

            

            <div class="icono">
                <img src="~/BENEFICIOS/motivacion.png"
                     asp-append-version="true"
                     alt="">
            </div>

            <h3 class="naranja-text">
                Motivación constante
            </h3>

            <p>
                Sistema de recompensas,
                insignias y logros que
                incentivan el aprendizaje
                todos los días.
            </p>

        </div>
        <!-- Tarjeta 4 -->

        <div class="card-beneficio">

            

            <div class="icono">
                <img src="~/BENEFICIOS/entorno.png"
                     asp-append-version="true"
                     alt="Entorno Seguro">
            </div>

            <h3 class="azul-text">
                Entorno seguro
            </h3>

            <p>
                Plataforma 100% segura y libre de contenido
                inapropiado para niños, garantizando una
                experiencia educativa confiable.
            </p>

        </div>

        <!-- Tarjeta 5 -->

        <div class="card-beneficio">

            

            <div class="icono">
                <img src="~/BENEFICIOS/seguimiento .png"
                     asp-append-version="true"
                     alt="Seguimiento">
            </div>

            <h3 class="rosado-text">
                Seguimiento del progreso
            </h3>

            <p>
                Reportes para padres y docentes que
                permiten visualizar el avance del
                estudiante en tiempo real.
            </p>

        </div>

        <!-- Tarjeta 6 -->

        <div class="card-beneficio">

            

            <div class="icono">
                <img src="~/BENEFICIOS/acccesibilidad.png"
                     asp-append-version="true"
                     alt="Accesibilidad">
            </div>

            <h3 class="violeta-text">
                Accesible en cualquier lugar
            </h3>

            <p>
                Disponible desde computadoras,
                tabletas y celulares para aprender
                cuando y donde quieras.
            </p>

        </div>

    </div>

</section>
<!-- ===========================================
        BANNER FINAL
============================================ -->

<section class="banner-beneficios">

    <div class="banner-contenido">

        <div class="banner-texto">

            <div class="banner-icono">
                🧪
            </div>

            <div>

                <h2>
                    ¡Cada día es una nueva aventura!
                </h2>

                <p>
                    Con <strong>EduClick</strong>,
                    aprender es <span>emocionante</span>,
                    fácil y lleno de descubrimientos.
                </p>

            </div>

        </div>


        <div class="banner-personaje">

            <img src="~/BENEFICIOS/tigreB.png"
                 alt="tigre">

        </div>


        <div class="banner-boton">

            <a href="#" class="btn-comenzar">
                Comenzar ahora 🚀
            </a>

        </div>

    </div>

</section>
