@model EC.Models.Evidencia

@{
    Layout = "_Layout";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Calificar Evidencia</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            width: 450px;
            box-shadow: 0 10px 20px rgba(0,0,0,.1);
        }

        h2 {
            margin-bottom: 20px;
        }

        input[type=number] {
            width: 100%;
            padding: 10px;
            font-size: 18px;
            margin-top: 10px;
            margin-bottom: 20px;
        }

        button {
            background: #4CAF50;
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            cursor: pointer;
        }

            button:hover {
                background: #45a049;
            }
    </style>

</head>
<body>

    <div class="card">

        <h2>Calificar Evidencia</h2>

        <form asp-action="Calificar" method="post">

            <input type="hidden" asp-for="Id" />

            <p>
                <strong>Estudiante:</strong>
                @Model.NombreEstudiante
            </p>

            <p>
                <strong>Archivo:</strong>
                @Model.NombreArchivo
            </p>

            <label>Nota (1.0 a 5.0)</label>

            <input asp-for="Nota"
                   type="number"
                   min="1"
                   max="5"
                   step="0.1"
                   required />

            <button type="submit">
                Guardar Calificación
            </button>

        </form>

    </div>

</body>
</html>