@model IEnumerable<EC.Models.Evidencia>

@{
    ViewBag.Title = "Evidencias";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="alert alert-info text-center">
    📢 Recuerda: solo sube evidencias relacionadas con tus actividades académicas.
</div>

<div class="evidencias-container">
    <main class="content-grid">
        <section class="main-card">

            @if (ViewBag.Mensaje != null)
            {
                <div class="alerta-exito">@ViewBag.Mensaje</div>
            }
            @using (Html.BeginForm("SubirArchivo", "Evidencias", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <label class="upload-area" for="archivo">
                    <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
                    <h2>Arrastra y suelta tu evidencia aquí</h2>
                    <p>o haz clic para seleccionar un archivo</p>
                    <div class="upload-btn">
                        <i class="fa-solid fa-file-circle-plus"></i> Seleccionar archivo
                    </div>
                </label>

                <!-- Input de archivo -->
                <input type="file" id="archivo" name="archivo" hidden accept=".jpg,.jpeg,.png,.pdf" required />
                <span id="file-name" style="display:block; margin-top:10px; font-size: 0.9em; color:#555;"></span>

                <script>
                    document.getElementById('archivo').addEventListener('change', function() {
                        if (this.files.length > 0) {
                            document.getElementById('file-name').textContent = "📄 " + this.files[0].name;
                        }
                    });
                </script>

                <!-- Botón de subir -->
                <button type="submit" class="btn btn-success">Subir Evidencia</button>
            }
            <h2>Mis evidencias</h2>
            @if (Model != null && Model.Any())
            {
                foreach (var evidencia in Model)
                {
                    <div class="evidencia-card">
                        <div class="evidencia-header">
                            <i class="fa-solid fa-folder"></i>
                            <span>@evidencia.NombreArchivo</span>
                        </div>
                        <div class="evidencia-info">
                            <p>👤 Estudiante: @evidencia.NombreEstudiante</p>
                            <p>📅 Fecha: @evidencia.FechaEntrega.ToString("dd/MM/yyyy")</p>
                            <p class="estado @(evidencia.Estado.ToLower())">Estado: @evidencia.Estado</p>

                            @if (evidencia.Nota != null)
                            {
                                <p>⭐ Nota: @evidencia.Nota</p>
                                <p>📝 Observación: @evidencia.Observacion</p>
                            }

                            <a href="~/uploads/@evidencia.NombreArchivo" target="_blank" class="btn btn-primary btn-sm">
                                Ver trabajo
                            </a>
                        </div>

                        @if (!string.IsNullOrEmpty(evidencia.MensajeConfirmacion))
                        {
                            <div class="mensaje-ok">✅ @evidencia.MensajeConfirmacion</div>
                        }
                    </div>
                }
            }
            else
            {
                <p>No tienes evidencias registradas aún 📭</p>
            }

            <div class="bottom-info">
                <i class="fa-solid fa-shield-heart"></i>
                Recuerda: Sube solo evidencias relacionadas con tus actividades de aprendizaje
            </div>
        </section>
    </main>
</div>

<script>
    document.getElementById('archivo').addEventListener('change', function() {
        document.getElementById('file-name').textContent = this.files[0].name;
    });
</script>
