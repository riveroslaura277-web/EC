@{
    ViewData["Title"] = "Recuperar Contraseña";
}
<h2>Recuperar Contraseña</h2>

@if (TempData["Error"] != null)
{
    <div style="color:red">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div style="color:green">@TempData["Success"]</div>
}

<form asp-action="RecuperarContrasena" asp-controller="Usuario" method="post">
    <input type="email" name="Email" placeholder="Correo electrónico" required />
    <button type="submit">Enviar enlace</button>
</form>
@if (ViewBag.Enlace != null)
{
    <hr />
    <p><strong>Enlace de recuperación:</strong></p>
    <a href="@ViewBag.Enlace">@ViewBag.Enlace</a>
}