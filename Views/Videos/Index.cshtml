@{
    ViewData["Title"] = "Videos Educativos";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/site.css" />
<link rel="stylesheet" href="~/css/Videos.css" />

<div class="contenedor">

    <!-- ENCABEZADO -->
    <header class="header-videos">

        <div class="logo-seccion">
            <img src="~/VIDEOS/Logo.png" alt="Logo">
        </div>

        <div class="saludo">
            <h2>¡Hola, Sofía! 👋</h2>
            <p>Hoy es un gran día para aprender cosas nuevas. 🌱</p>
        </div>

        <div class="acciones">

            <div class="puntos">
                <img src="~/VIDEOS/Puntos.png" alt="Puntos">
                <div>
                    <h3>1200</h3>
                    <span>Puntos</span>
                </div>
            </div>

            <div class="notificacion">
                <i class="fa-regular fa-bell"></i>
                <span>3</span>
            </div>

            <div class="perfil">
                <img src="~/VIDEOS/icono avatar.png" alt="Avatar">
                <div>
                    <h4>Sofía</h4>
                    <p>Estudiante</p>
                </div>
            </div>

        </div>

    </header>

    <!-- TITULO -->
    <section class="titulo-videos">

        <div class="icono-video">
            <i class="fa-solid fa-play"></i>
        </div>

        <div>
            <h1>Videos Educativos</h1>
            <p>Aprende viendo, escucha y descubre nuevos temas.</p>
        </div>

    </section>

    <!-- FILTROS -->
    <section class="categorias">

        <button class="activo">Todos</button>
        <button>Matemáticas</button>
        <button>Ciencia</button>
        <button>Historia</button>
        <button>Geografía</button>
        <button>Lenguaje</button>
        <button>Arte</button>
        <button>Tecnología</button>
        <button>Valores</button>

    </section>

    <!-- TARJETAS -->
    <section class="grid-videos">

        <!-- aquí dejas todas tus card-video exactamente como están -->

    </section>

</div>