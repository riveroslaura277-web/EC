@model IEnumerable<SUBIReVIDENCIAS.Models.Observacion>

<div class="container mt-4">
    <h2 class="mb-4">📒 Bloc de Notas del Docente</h2>

    <div class="row">
        <div class="col-md-4">
            <div class="card p-3 shadow-sm bg-light">
                <h5>Nueva Nota</h5>
                @using (Html.BeginForm("GuardarObservacion", "Docente", FormMethod.Post))
                {
                    <select name="estudianteId" class="form-control mb-2">
                    </select>
                    <textarea name="texto" class="form-control mb-2" rows="5" placeholder="Escribe aquí..."></textarea>
                    <button type="submit" class="btn btn-primary w-100">Guardar Nota</button>
                }
            </div>
        </div>

        <div class="col-md-8">
            @foreach (var nota in Model)
            {
                <div class="card mb-3 border-left-primary shadow-sm">
                    <div class="card-body">
                        <h6 class="text-primary font-weight-bold">@nota.Estudiante.Nombre</h6>
                        <p class="card-text">@nota.Texto</p>
                        <small class="text-muted"><i class="fa fa-clock"></i> @nota.Fecha.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>