@model SUBIReVIDENCIAS.Models.DocenteViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Panel Docente</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/docente.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
    <!-- Sidebar y Main se quedan igual -->
    <div class="sidebar">
        <h2><i class="fa-solid fa-chalkboard-user"></i> Docente</h2>
        <a href="/Docente/PanelDocente"><i class="fa-solid fa-house"></i> Inicio</a>
        <a href="/Docente/Tareas"><i class="fa-solid fa-folder-open"></i> Tareas</a>
        <a href="/Docente/Estudiantes"><i class="fa-solid fa-user-graduate"></i> Estudiantes</a>
        <a href="/Docente/Asistencia"><i class="fa-solid fa-clipboard-list"></i> Asistencia</a>
        <a href="/Docente/Observaciones"><i class="fa-solid fa-note-sticky"></i> Observaciones</a>
        <a href="#" data-bs-toggle="modal" data-bs-target="#modalPerfil">
            <i class="fa-solid fa-user"></i> Perfil
        </a>
        <a href="/Docente/Cursos"><i class="fa-solid fa-book"></i> Cursos</a>
    </div>

    <div class="main">
        <header class="topbar">
            <h1>Bienvenido, @Model.Nombre 👋</h1>
            <i class="fa-solid fa-user-circle perfil-top"></i>
        </header>


        <div class="dashboard">
            <div class="card-panel">
                <i class="fa-solid fa-folder-open"></i>
                <h3>Evidencias</h3>
                <a href="/Docente/Tareas">Ir a Tareas</a>
            </div>

            <div class="card-panel">
                <i class="fa-solid fa-clipboard-list"></i>
                <h3>Asistencia</h3>
                <a href="/Docente/Asistencia">Ver Asistencia</a>
            </div>

            <div class="card-panel">
                <i class="fa-solid fa-user-graduate"></i>
                <h3>Estudiantes</h3>
                <a href="/Docente/Estudiantes">Ver Estudiantes</a>
            </div>

            <div class="card-panel">
                <i class="fa-solid fa-book"></i>
                <h3>Cursos</h3>
                <a href="/Docente/Cursos">Ver Cursos</a>
            </div>
        </div>


    </div>

    <!-- EL MODAL DEBE IR AQUÍ DENTRO DEL BODY -->
    <div class="modal fade" id="modalPerfil" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: rgba(255, 255, 255, 0.2); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 20px; color: white; border: none;">
                <div class="modal-header border-0">
                    <h5 class="modal-title"><i class="fa-solid fa-user-edit"></i> Mi Perfil</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @using (Html.BeginForm("EditarPerfil", "Docente", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        <div class="mb-3">
                            <label class="form-label">Nombre Completo</label>
                            <input type="text" name="Nombre" class="form-control bg-transparent text-white border-white" placeholder="Nombre" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Correo Electrónico</label>
                            <input type="email" name="Correo" class="form-control bg-transparent text-white border-white" placeholder="correo@ejemplo.com" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Foto de Perfil</label>
                            <input type="file" name="foto" class="form-control bg-transparent text-white border-white" />
                        </div>
                        <button type="submit" class="btn btn-light w-100 fw-bold">Guardar Cambios</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>